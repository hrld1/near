# PostgreSQL (docker-compose.yml levanta una instancia lista para usar)
DATABASE_URL="postgresql://near:near@localhost:5432/near"

# Genera uno con: openssl rand -base64 32
AUTH_SECRET="@!HY#*eKskMbiwm8~T5XjyE41Sch2AL-3ZJ9"

# Necesario en desarrollo detras de proxy / puertos no estandar
AUTH_TRUST_HOST=true

# --- Opcional: TURN para videollamadas en redes con NAT estricto ---
# La videollamada funciona P2P con STUN publico en la mayoria de redes.
# Si alguno esta detras de CGNAT/red universitaria, configura un TURN
# (ej. Twilio, coturn propio, o metered.ca gratis) y descomenta:
# NEXT_PUBLIC_TURN_URL="turn:tu-servidor:3478"
# NEXT_PUBLIC_TURN_USERNAME="usuario"
# NEXT_PUBLIC_TURN_CREDENTIAL="secreto"

# --- Pendiente (no implementado, ver README): Spotify OAuth ---
# SPOTIFY_CLIENT_ID=""
# SPOTIFY_CLIENT_SECRET=""
