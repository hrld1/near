# PostgreSQL. En local, docker-compose.yml levanta una instancia lista.
# En produccion, la cadena de Neon (pooled) con sslmode=require:
# DATABASE_URL="postgresql://usuario:password@ep-xxx-pooler.region.aws.neon.tech/near?sslmode=require"
DATABASE_URL="postgresql://near:near@localhost:5432/near"

# Genera uno con: openssl rand -base64 32 (en produccion, uno DISTINTO y secreto)
AUTH_SECRET="@!HY#*eKskMbiwm8~T5XjyE41Sch2AL-3ZJ9"

# Necesario detras de proxy (Koyeb, Caddy) y en puertos no estandar
AUTH_TRUST_HOST=true

# Version desplegada; el CI la fija al SHA del commit (visible en /api/health)
# APP_VERSION="dev"

# --- Opcional: notificaciones push (PWA) ---
# Sin estas claves la app funciona igual; solo se desactiva el push.
# Generalas con: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:tu-email@ejemplo.com"

# --- Opcional: TURN para videollamadas en redes con NAT estricto ---
# La videollamada funciona P2P con STUN publico en la mayoria de redes.
# Si alguno esta detras de CGNAT/red universitaria hace falta un TURN.
#
# Ruta recomendada (gratis, 1 TB/mes): Cloudflare Realtime TURN.
# En el dashboard de Cloudflare → Realtime → TURN keys, crea una clave y pon:
# CF_TURN_KEY_ID=""
# CF_TURN_API_TOKEN=""
# Las credenciales caducan: el servidor las genera y cachea (/api/ice) y la
# llamada las recoge justo antes de conectar. Sin claves, todo sigue igual.
#
# Alternativa con credenciales estaticas (coturn propio, Twilio, metered.ca):
# NEXT_PUBLIC_TURN_URL="turn:tu-servidor:3478"
# NEXT_PUBLIC_TURN_USERNAME="usuario"
# NEXT_PUBLIC_TURN_CREDENTIAL="secreto"

# --- Opcional: Spotify Connect (escuchar música juntos, de verdad) ---
# Sin estas claves, la sala usa el modo companion honesto y nada de Spotify
# se activa. Con ellas, cada uno conecta su cuenta y el líder comparte lo que
# suena; el seguidor (Premium + dispositivo activo) lo reproduce a la vez.
# Crea una app en https://developer.spotify.com/dashboard y añade como
# Redirect URI: <tu-dominio>/api/spotify/callback (en local
# http://localhost:3000/api/spotify/callback).
# SPOTIFY_CLIENT_ID=""
# SPOTIFY_CLIENT_SECRET=""

# --- Opcional: almacenamiento en S3 (o compatible: R2, MinIO) ---
# Sin esto, los archivos se guardan en disco local (carpeta ./uploads). Con
# esto, se guardan y sirven desde S3 — sin cambiar la URL /api/files/... ni
# añadir dependencias (la firma SigV4 se hace con el crypto de Node).
# Define los cuatro para activarlo; S3_ENDPOINT solo para S3-compatibles.
# S3_BUCKET=""
# S3_REGION="eu-west-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""   # p. ej. https://<accountid>.r2.cloudflarestorage.com

# --- Opcional: Redis para despliegue multi-nodo ---
# El bus de eventos en vivo (SSE) es en memoria y vale para un solo proceso.
# Con varias instancias, define REDIS_URL para repartir los eventos entre
# ellas. Requiere instalar el cliente: npm i ioredis
# REDIS_URL=""   # p. ej. redis://usuario:password@host:6379
